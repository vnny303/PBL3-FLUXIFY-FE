# ─── Storefront Environment Variables ───────────────────────────────────────
# Copy file này thành .env rồi điền giá trị thật vào
# Không commit file .env lên Git nếu có chứa API keys hoặc secrets

# ─── API ─────────────────────────────────────────────────────────────────────
# URL gốc của Backend API
VITE_API_URL=http://localhost:5119

# ─── Tenant / Storefront ─────────────────────────────────────────────────────
# Subdomain xác định cửa hàng (dùng khi login/đăng ký và load tenant)
# Dev local: đặt thành tên subdomain đã tạo trên BE
VITE_STOREFRONT_SUBDOMAIN=your-shop-subdomain

# ─── Multi-app URLs ───────────────────────────────────────────────────────────
# URL của Merchant app (dùng để redirect nếu user đăng nhập sai app)
VITE_MERCHANT_APP_URL=http://localhost:5174
